# ============================================================================
# Content Engine — Environment Variables Template
# Copy this file to .env.local and fill in real values
# NEVER commit .env.local to version control
# ============================================================================

# ── Site URL (used for SEO metadata, sitemap, OG images) ─────────────────────
NEXT_PUBLIC_SITE_URL=https://zerohuman.vercel.app

# ── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>

# ⚠️ Server-side ONLY — never expose in frontend bundles
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# ── Python Backend ────────────────────────────────────────────────────────────
PYTHON_BACKEND_URL=http://localhost:8082

# ── Security ──────────────────────────────────────────────────────────────────
# C-06: Random secret for scheduler endpoint protection
# Generate with: openssl rand -hex 32
SCHEDULER_SECRET=<generate-with-openssl-rand-hex-32>

# H-01: CORS — comma-separated origins allowed to call the Python backend
ALLOWED_ORIGINS=http://localhost:3000

# ── AI API Keys (at least one required) ───────────────────────────────────────
# Anthropic (preferred — used for Claude Sonnet/Opus)
ANTHROPIC_API_KEY=<sk-ant-...>

# OpenRouter (alternative / fallback pool)
OPENROUTER_API_KEY=<sk-or-...>

# OpenAI (for DALL-E 3 image generation and optional LLM routing)
# OPENAI_API_KEY=<sk-...>

# ── LLM Routing ──────────────────────────────────────────────────────────────
# If TRUE, routes LLM calls through Anthropic API (uses your subscription)
# If FALSE, uses OpenRouter free/paid models (default)
USE_CLAUDE_SUBSCRIPTION=false

# Daily cost cap in USD — pipeline refuses new LLM calls when exceeded
DAILY_COST_CAP_USD=5.0

# ── OpenClaw LLM Gateway (optional) ──────────────────────────────────────────
# Internal Claude subscription-sharing proxy (used when USE_CLAUDE_SUBSCRIPTION=true)
# OPENCLAW_API_URL=http://localhost:9000
# OPENCLAW_DEFAULT_MODEL=claude-sonnet-4-20250514

# ── Research API Keys ─────────────────────────────────────────────────────────
# Serper.dev — Google search API for research retrievers
SERPER_API_KEY=<serper-key>

# YouTube Data API v3 — for trend retriever
YOUTUBE_API_KEY=<yt-api-key>

# Tavily — AI-powered search retriever (alternative to Serper)
# TAVILY_API_KEY=<tvly-...>

# ── Research Tuning ───────────────────────────────────────────────────────────
DEDUP_THRESHOLD=0.85
MAX_ITEMS_PER_RETRIEVER=100

# ── Email Delivery ────────────────────────────────────────────────────────────
# Resend — transactional email for newsletter delivery
RESEND_API_KEY=<re_...>

# ── Image Generation ──────────────────────────────────────────────────────────
# Replicate — FLUX, SDXL, etc. (get token at replicate.com/account)
REPLICATE_API_TOKEN=<r8_...>

# Pillo — carousel specialist (optional)
# PILLO_API_KEY=<pillo-...>

# Default backend for new brands: mock | replicate | openai | pillo | openrouter | anthropic
# Use mock during development to avoid image API costs
DEFAULT_IMAGE_BACKEND=mock
DEFAULT_IMAGE_MODEL=mock-v1

# ── Video Generation ──────────────────────────────────────────────────────────
# Supabase storage bucket name for generated video files
VIDEO_STORAGE_BUCKET=videos

# Path to HyperFrames binary (optional — for video-to-carousel pipeline)
# HYPERFRAMES_BIN=/usr/local/bin/hyperframes

# ── Postiz Social Publishing ──────────────────────────────────────────────────
# Mode: self_hosted | cloud | disabled
#   self_hosted → docker-compose.postiz.yaml (local)
#   cloud       → Postiz SaaS / managed instance
#   disabled    → skip social publishing entirely
POSTIZ_MODE=disabled

# Postiz API URL:
#   Self-hosted: http://localhost:3001  (Docker mapped port)
#   Cloud:       https://api.postiz.com  (or your custom Postiz domain)
POSTIZ_API_URL=http://localhost:3001

# Postiz API key — generate in Postiz UI → Settings → API
POSTIZ_API_KEY=<postiz-api-key>

# ── Newsletter Sender Identity ────────────────────────────────────────────────
# Used as the From: header for newsletter emails sent via Resend.
# Can be overridden per-brand in Settings → Brand Context.
NEWSLETTER_FROM_EMAIL=newsletter@yourdomain.com
NEWSLETTER_FROM_NAME=Your Brand

# ── Brand Secrets Encryption ──────────────────────────────────────────────────
# Fernet key for encrypting per-brand API keys in brand_integrations table.
# Required for Brevo, Heygen, OpenClaw, and any future per-brand integrations.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
BRAND_SECRETS_ENCRYPTION_KEY=<fernet-key-here>

# ── Content Scoring ────────────────────────────────────────────────────────────
SCORING_MODEL=google/gemma-4-150b:free
AUTO_APPROVE_THRESHOLD=8.0
AUTO_REJECT_THRESHOLD=3.0

# ── Scheduler Brand Targeting ─────────────────────────────────────────────────
# Leave blank → scheduler runs for ALL active brands (fan-out mode)
# Set to a brand UUID → scheduler runs for that single brand only
SCHEDULER_BRAND_ID=

# ── Internal Service URLs ─────────────────────────────────────────────────────
# Next.js base URL — used by Python backend for internal render calls
NEXTJS_URL=http://localhost:3000

# Dashboard URL — used for deep links in Telegram alerts
DASHBOARD_URL=http://localhost:3000

# Deep Research sidecar — local-deep-research Docker container
# Start with: docker run -d -p 5000:5000 --name ldr ghcr.io/LearningCircuit/local-deep-research:latest
DEEP_RESEARCH_URL=http://localhost:5000

# ── Logging & Observability ───────────────────────────────────────────────────
LOG_LEVEL=INFO
ENVIRONMENT=development
SERVICE_NAME=content-engine

# ── Auth Middleware ───────────────────────────────────────────────────────────
# Seconds to cache JWT verification results (reduces Supabase round-trips)
AUTH_CACHE_TTL_SECONDS=300

# ── Fallback Monitoring ───────────────────────────────────────────────────────
# Alert when LLM fallback rate exceeds this % of daily calls
FALLBACK_ALERT_THRESHOLD=10.0
# Hour (UTC) when the daily fallback counter resets (0 = midnight UTC)
FALLBACK_DAILY_RESET_HOUR=0

# ── MCP ───────────────────────────────────────────────────────────────────────
CONTEXT7_MCP_URL=https://mcp.context7.com/mcp

# ── Optional: Alerts ──────────────────────────────────────────────────────────
# Telegram bot for pipeline alerts (errors, daily summaries)
# Create a bot with @BotFather; get the chat ID with @userinfobot
# TELEGRAM_BOT_TOKEN=<bot-token>
# TELEGRAM_CHAT_ID=<chat-id>
# TELEGRAM_WEBHOOK_SECRET=<generate-with-openssl-rand-hex-32>

# ── Optional: Content Enrichment ─────────────────────────────────────────────
# Firecrawl — premium content extraction (falls back to trafilatura if not set)
# FIRECRAWL_API_KEY=<fc-...>
# PP_FIRECRAWL_BIN=/usr/local/bin/pp-firecrawl

# ── Optional: Brevo Email Marketing ──────────────────────────────────────────
# Required only if email_marketing_enabled feature flag is on for any brand
# BREVO_API_KEY=<your-brevo-api-key>
# BREVO_WEBHOOK_SECRET=<generate-with-openssl-rand-hex-32>

# ── Optional: Gmail Retriever ─────────────────────────────────────────────────
# Path to Google OAuth credentials JSON (from Google Cloud Console)
# GMAIL_CREDENTIALS_JSON=/path/to/credentials.json
# Path to stored OAuth token (auto-created after first auth flow)
# GMAIL_TOKEN_JSON=/path/to/token.json

# ── Optional: X / Twitter Retriever ──────────────────────────────────────────
# X_BEARER_TOKEN=<x-bearer-token>
# PP_X_TWITTER_BIN=/usr/local/bin/pp-x-twitter

# ── Optional: Tavily Retriever Binary ─────────────────────────────────────────
# PP_TAVILY_BIN=/usr/local/bin/pp-tavily
