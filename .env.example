# ============================================================================
# Content Engine — Environment Variables Template
# Copy this file to .env.local and fill in real values
# NEVER commit .env.local to version control
# ============================================================================

# ── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>

# ⚠️ Server-side ONLY — never expose in frontend bundles
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# ── Python Backend ────────────────────────────────────────────────────────────
PYTHON_BACKEND_URL=http://localhost:8000

# ── Security ──────────────────────────────────────────────────────────────────
# C-06: Random secret for scheduler endpoint protection
# Generate with: openssl rand -hex 32
SCHEDULER_SECRET=<generate-with-openssl-rand-hex-32>

# H-01: CORS — comma-separated origins allowed to call the Python backend
ALLOWED_ORIGINS=http://localhost:3000

# ── AI API Keys (at least one required) ───────────────────────────────────────
# Anthropic (preferred — used for Claude Sonnet/Opus)
ANTHROPIC_API_KEY=<sk-ant-...>

# OpenRouter (alternative)
OPENROUTER_API_KEY=<sk-or-...>

# ── Research API Keys ─────────────────────────────────────────────────────────
# Serper.dev — Google search API for research retrievers
SERPER_API_KEY=<serper-key>

# YouTube Data API v3 — for trend retriever
YOUTUBE_API_KEY=<yt-api-key>

# ── Email Delivery ────────────────────────────────────────────────────────────
# Resend — transactional email for newsletter delivery
RESEND_API_KEY=<re_...>

# ── Image Generation ──────────────────────────────────────────────────────────
# Replicate — FLUX, SDXL, etc. (get token at replicate.com/account)
REPLICATE_API_TOKEN=<r8_...>

# OpenAI — DALL-E 3 (get key at platform.openai.com)
# OPENAI_API_KEY=<sk-...>

# Pillo — carousel specialist (optional)
# PILLO_API_KEY=<pillo-...>

# Default backend for new brands: mock | replicate | openai | pillo | openrouter | anthropic
# Use mock during development to avoid image API costs
DEFAULT_IMAGE_BACKEND=mock
DEFAULT_IMAGE_MODEL=mock-v1

# ── Postiz Social Publishing ──────────────────────────────────────────────────
# Mode: self_hosted | cloud | disabled
#   self_hosted → docker-compose.postiz.yaml (local)
#   cloud       → Postiz SaaS / managed instance
#   disabled    → skip social publishing entirely
POSTIZ_MODE=disabled

# Postiz API URL:
#   Self-hosted: http://localhost:3001  (Docker mapped port)
#   Cloud:       https://api.postiz.com  (or your custom Postiz domain)
POSTIZ_API_URL=http://localhost:3001

# Postiz API key — generate in Postiz UI → Settings → API
POSTIZ_API_KEY=<postiz-api-key>

# ── Newsletter Sender Identity ────────────────────────────────────────────────
# Used as the From: header for newsletter emails sent via Resend.
# Can be overridden per-brand in Settings → Brand Context.
NEWSLETTER_FROM_EMAIL=newsletter@yourdomain.com
NEWSLETTER_FROM_NAME=Your Brand

# ── Scheduler Brand Targeting ─────────────────────────────────────────────────
# Leave blank → scheduler runs for ALL active brands (fan-out mode)
# Set to a brand UUID → scheduler runs for that single brand only
SCHEDULER_BRAND_ID=

# ── Optional: Alerts ──────────────────────────────────────────────────────────
# Telegram bot for pipeline alerts (errors, daily summaries)
# Create a bot with @BotFather and get the chat ID with @userinfobot
# TELEGRAM_BOT_TOKEN=<bot-token>
# TELEGRAM_CHAT_ID=<chat-id>

# ── Optional: Content Enrichment ─────────────────────────────────────────────
# Firecrawl — premium content extraction (falls back to trafilatura if not set)
# FIRECRAWL_API_KEY=<fc-...>

# ── Brand Secrets Encryption ──────────────────────────────────────────────────
# Required for per-brand credential vault (Postiz, Serper, Tavily, etc.)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
BRAND_SECRETS_ENCRYPTION_KEY=<fernet-key-here>

# ── Deep Research Sidecar ─────────────────────────────────────────────────────
# URL of the local-deep-research Docker container
# Start with: docker run -d -p 5000:5000 --name ldr ghcr.io/LearningCircuit/local-deep-research:latest
# DEEP_RESEARCH_URL=http://localhost:5000

# ── Brevo Email Marketing (optional) ─────────────────────────────────────────
# Required only if email_marketing_enabled feature flag is on for any brand
# BREVO_API_KEY=<your-brevo-api-key>
# BREVO_WEBHOOK_SECRET=<generate-with-openssl-rand-hex-32>
