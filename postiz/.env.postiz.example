# Postiz Environment — copy to .env.postiz and fill OAuth credentials
# This file is used ONLY when POSTIZ_MODE=self_hosted

# ── OAuth: LinkedIn ───────────────────────────────────────────────────────────
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# ── OAuth: X / Twitter ────────────────────────────────────────────────────────
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=

# ── OAuth: Instagram / Facebook (Meta) ────────────────────────────────────────
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# ── OAuth: TikTok ─────────────────────────────────────────────────────────────
TIKTOK_CLIENT_ID=
TIKTOK_CLIENT_SECRET=

# ── OAuth: YouTube / Google ───────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── OAuth: Reddit ─────────────────────────────────────────────────────────────
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# ── OAuth: Pinterest ──────────────────────────────────────────────────────────
PINTEREST_CLIENT_ID=
PINTEREST_CLIENT_SECRET=

# ── OAuth: Threads ────────────────────────────────────────────────────────────
THREADS_CLIENT_ID=
THREADS_CLIENT_SECRET=

# ── OAuth: Bluesky ────────────────────────────────────────────────────────────
BLUESKY_CLIENT_ID=
BLUESKY_CLIENT_SECRET=

# ── OAuth: Mastodon ───────────────────────────────────────────────────────────
MASTODON_CLIENT_ID=
MASTODON_CLIENT_SECRET=

# ── OAuth: Discord ────────────────────────────────────────────────────────────
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# ── OAuth: Slack ──────────────────────────────────────────────────────────────
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
